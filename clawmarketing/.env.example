# ───────────────────────────────────────────
# clawmarketing — environment configuration
# Copy to .env and fill in the ones you use.
# Engine gracefully skips any provider not configured.
# ───────────────────────────────────────────

# --- LLM providers (at least one required) ---
ZAI_API_KEY=
GROK_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=

# --- Publishers ---
# X (Twitter) — get from developer.x.com
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Postiz — get from your Postiz instance
POSTIZ_API_KEY=

# --- Brand selection ---
BRAND_KEY=example_brand
